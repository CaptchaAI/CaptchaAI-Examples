# CaptchaAI API credentials
# Get your API key from https://captchaai.com/dashboard (32 characters)
CAPTCHAAI_API_KEY=YOUR_API_KEY

# Target page configuration
# The gt value is static per site — find it in the page source or GeeTest init call
CAPTCHA_GT=YOUR_GT_VALUE
# The challenge token is dynamic — you MUST fetch a fresh one for each solve attempt
CAPTCHA_CHALLENGE=YOUR_CHALLENGE_VALUE
# Full URL of the page where the GeeTest widget loads
CAPTCHA_PAGEURL=https://example.com
# GeeTest API server (optional — leave empty if not needed)
CAPTCHA_API_SERVER=

# Polling configuration (optional)
POLL_INTERVAL=5
MAX_TIMEOUT=120
