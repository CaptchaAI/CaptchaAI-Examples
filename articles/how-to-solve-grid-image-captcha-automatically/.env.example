# CaptchaAI API credentials
# Get your API key from https://captchaai.com/dashboard (32 characters)
CAPTCHAAI_API_KEY=YOUR_API_KEY

# Grid Image CAPTCHA configuration
# Path to the grid CAPTCHA image file (PNG, JPG, etc.)
CAPTCHA_IMAGE_FILE=grid.png
# Text instructions describing what to select (e.g. "Select all squares with traffic lights")
CAPTCHA_INSTRUCTIONS=Select all squares with traffic lights

# Polling configuration (optional)
POLL_INTERVAL=5
MAX_TIMEOUT=120
