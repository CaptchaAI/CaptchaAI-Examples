# CaptchaAI API credentials
# Get your API key from https://captchaai.com/dashboard (32 characters)
CAPTCHAAI_API_KEY=YOUR_API_KEY

# Target page configuration
# Full URL of the page protected by Cloudflare Challenge
CAPTCHA_PAGEURL=https://example.com

# Proxy configuration (REQUIRED for Cloudflare Challenge)
# Format: login:password@ip:port
PROXY=login:password@ip:port
# Proxy type: HTTP, HTTPS, SOCKS4, or SOCKS5
PROXYTYPE=HTTP

# Polling configuration (optional)
POLL_INTERVAL=5
MAX_TIMEOUT=120
