# CaptchaAI API credentials
# Get your API key from https://captchaai.com/dashboard (32 characters)
CAPTCHAAI_API_KEY=YOUR_API_KEY

# Target page configuration
# reCAPTCHA v3 Enterprise sitekey from the target page (find in grecaptcha.enterprise.execute call)
CAPTCHA_SITEKEY=YOUR_SITE_KEY
# Full URL of the page where the reCAPTCHA widget loads
CAPTCHA_PAGEURL=https://example.com/login
# Optional data-s value from the page (leave empty if not present)
CAPTCHA_DATA_S=

# reCAPTCHA v3 specific parameters
# The action name used in grecaptcha.enterprise.execute (check the site's JS source)
CAPTCHA_ACTION=verify
# Minimum acceptable score (0.1 to 0.9, lower = less strict)
CAPTCHA_MIN_SCORE=0.3

# Polling configuration (optional)
POLL_INTERVAL=5
MAX_TIMEOUT=120
